<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DiscoveryApp.ForgotPasswordPage"
             Title="ForgotPasswordPage"
             BackgroundColor="#121212">
    <VerticalStackLayout Padding="30" 
                         Spacing="15" 
                         VerticalOptions="Center">
        <Label Text="Şifremi Unuttum" 
               FontSize="24" 
               FontAttributes="Bold" 
               TextColor="White" 
               HorizontalOptions="Center" 
               Margin="0,0,0,10" />
        <Label Text="Kayıtlı e-posta adresinizi girin, size şifrenizi yenilemeniz için bir bağlantı göndereceğiz." 
               FontSize="14" 
               TextColor="#AAAAAA" 
               HorizontalTextAlignment="Center" 
               Margin="0,0,0,20" />
        <Entry Placeholder="E-posta Adresi" 
               Keyboard="Email"
               TextColor="White" 
               PlaceholderColor="#AAAAAA"
               BackgroundColor="#1E1E1E" />
        <Button Text="Sıfırlama Bağlantısı Gönder" 
                BackgroundColor="#E50914" 
                TextColor="White" 
                FontAttributes="Bold" 
                CornerRadius="10" 
                HeightRequest="55" 
                Margin="0,15,0,0"
                Clicked="OnResetPasswordClicked" />
        <Button Text="Vazgeçtim, Giriş'e Dön" 
                BackgroundColor="Transparent" 
                TextColor="#AAAAAA" 
                FontSize="14" 
                Margin="0,10,0,0"
                Clicked="OnBackToLoginClicked" />
    </VerticalStackLayout>
</ContentPage>