<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DiscoveryApp.SignUpPage"
             Title="SignUpPage"
             BackgroundColor="#121212">
    <VerticalStackLayout Padding="30" 
                         Spacing="15" 
                         VerticalOptions="Center">
        <Label Text="Yeni Hesap Oluştur" 
               FontSize="24" 
               FontAttributes="Bold" 
               TextColor="White" 
               HorizontalOptions="Center" 
               Margin="0,0,0,20" />
        <Entry x:Name="UsernameEntry" 
               Placeholder="Kullanıcı Adı" 
               MaxLength="20"
               TextColor="White"
               PlaceholderColor="#AAAAAA"
               BackgroundColor="#1E1E1E" />
        <Entry x:Name="EmailEntry" 
               Placeholder="E-posta Adresi" 
               Keyboard="Email"
               MaxLength="40"
               TextColor="White" 
               PlaceholderColor="#AAAAAA" 
               BackgroundColor="#1E1E1E" />
        <Grid ColumnDefinitions="*, Auto"
              BackgroundColor="#1E1E1E">
            <Entry x:Name="PasswordEntry" 
                   Placeholder="Şifre" 
                   IsPassword="True" 
                   MaxLength="20"
                   TextColor="White"
                   PlaceholderColor="#AAAAAA" />
            <Button Grid.Column="1" 
                    Text="👁" 
                    BackgroundColor="Transparent" 
                    TextColor="#AAAAAA"
                    FontSize="20"
                    Margin="0,0,10,0"
                    Pressed="OnPasswordPressed"
                    Released="OnPasswordReleased" />
        </Grid>
        <Grid ColumnDefinitions="*, Auto" 
              BackgroundColor="#1E1E1E">
            <Entry x:Name="PasswordConfirmEntry"
                   Placeholder="Şifre (Tekrar)" 
                   IsPassword="True" 
                   MaxLength="20"
                   TextColor="White" 
                   PlaceholderColor="#AAAAAA" />
            <Button Grid.Column="1" 
                    Text="👁" 
                    BackgroundColor="Transparent" 
                    TextColor="#AAAAAA"
                    FontSize="20"
                    Margin="0,0,10,0"
                    Pressed="OnPasswordConfirmPressed"
                    Released="OnPasswordConfirmReleased" />
        </Grid>
        <Button Text="Kayıt Ol" 
                BackgroundColor="#E50914" 
                TextColor="White" 
                FontAttributes="Bold" 
                CornerRadius="10" 
                HeightRequest="55" 
                Margin="0,15,0,0"
                Clicked="OnRegisterButtonClicked" />
        <Button Text="Zaten hesabım var, Giriş Yap" 
                BackgroundColor="Transparent" 
                TextColor="#AAAAAA" 
                FontSize="14" 
                Margin="0,10,0,0"
                Clicked="OnBackToLoginClicked" />
    </VerticalStackLayout>
</ContentPage>