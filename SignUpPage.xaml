<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DiscoveryApp.SignUpPage"
             Title="SignUpPage"
             BackgroundColor="#121212">
    <VerticalStackLayout Padding="30" 
                         Spacing="15" 
                         VerticalOptions="Center">
        <Label Text="Yeni Hesap Oluştur" 
               FontSize="24" 
               FontAttributes="Bold" 
               TextColor="White" 
               HorizontalOptions="Center" 
               Margin="0,0,0,20" />
        <Entry Placeholder="Kullanıcı Adı" 
               TextColor="White"
               PlaceholderColor="#AAAAAA" 
               BackgroundColor="#1E1E1E" />
        <Entry Placeholder="E-posta Adresi" 
               Keyboard="Email"
               TextColor="White"
               PlaceholderColor="#AAAAAA" 
               BackgroundColor="#1E1E1E" />
        <Entry Placeholder="Şifre"
               IsPassword="True" 
               TextColor="White" 
               PlaceholderColor="#AAAAAA"
               BackgroundColor="#1E1E1E" />
        <Entry Placeholder="Şifre (Tekrar)"
               IsPassword="True" 
               TextColor="White"
               PlaceholderColor="#AAAAAA" 
               BackgroundColor="#1E1E1E" />
        <Button Text="Kayıt Ol" 
                BackgroundColor="#E50914" 
                TextColor="White" 
                FontAttributes="Bold" 
                CornerRadius="10" 
                HeightRequest="55" 
                Margin="0,15,0,0"
                Clicked="OnRegisterButtonClicked" />
        <Button Text="Zaten hesabım var, Giriş Yap" 
                BackgroundColor="Transparent" 
                TextColor="#AAAAAA" 
                FontSize="14" 
                Margin="0,10,0,0"
                Clicked="OnBackToLoginClicked" />
    </VerticalStackLayout>
</ContentPage> 