<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DiscoveryApp.LoginPage"
             Title="LoginPage"
             BackgroundColor="#121212">
    <VerticalStackLayout Padding="30"
                         Spacing="20" 
                         VerticalOptions="Center">
        <Label Text="DiscoveryApp'e Hoş Geldin" 
               FontSize="24" 
               FontAttributes="Bold" 
               TextColor="White" 
               HorizontalOptions="Center" 
               Margin="0,0,0,30" />
        <Entry x:Name="UsernameEntry" 
               Placeholder="Kullanıcı Adı" 
               MaxLength="20"
               TextColor="White"
               PlaceholderColor="#AAAAAA"
               BackgroundColor="#1E1E1E" />
        <Grid ColumnDefinitions="*, Auto"
              BackgroundColor="#1E1E1E">
            <Entry x:Name="PasswordEntry"
                   Placeholder="Şifre" 
                   IsPassword="True" 
                   MaxLength="20"
                   TextColor="White"
                   PlaceholderColor="#AAAAAA" />
            <Button x:Name="EyeBtn"
                    Grid.Column="1" 
                    Text="👁" 
                    TextColor="#AAAAAA"
                    BackgroundColor="Transparent"
                    FontSize="20"
                    Margin="0,0,10,0"
                    Pressed="OnPasswordPressed"
                    Released="OnPasswordReleased" />
        </Grid>
        <Button Text="Giriş Yap" 
                BackgroundColor="#E50914" 
                TextColor="White" 
                FontAttributes="Bold" 
                CornerRadius="10" 
                HeightRequest="55" 
                Margin="0,20,0,0"
                Clicked="OnLoginButtonClicked" />
        <HorizontalStackLayout HorizontalOptions="Center"
                               Spacing="15"
                               Margin="0,15,0,0">
            <Button Text="Şifremi Unuttum"
                    BackgroundColor="Transparent"
                    TextColor="#AAAAAA"
                    FontSize="14"
                    Clicked="OnForgotPasswordClicked" />
            <Label Text="|"
                   TextColor="#555555"
                   VerticalOptions="Center" />
            <Button Text="Kayıt Ol"
                    BackgroundColor="Transparent"
                    TextColor="#E50914"
                    FontSize="14"
                    FontAttributes="Bold"
                    Clicked="OnSignUpClicked" />
        </HorizontalStackLayout>
    </VerticalStackLayout>
</ContentPage>