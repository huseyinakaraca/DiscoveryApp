<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="DiscoveryApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:DiscoveryApp"
    Title="DiscoveryApp"
    Shell.TabBarTitleColor="White"
    Shell.TabBarUnselectedColor="#888888"
    Shell.TabBarBackgroundColor="#1E1E1E"
    Shell.ForegroundColor="#E50914">
    <TabBar>
        <ShellContent
            Title="Ana Sayfa"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />
        <ShellContent
            Title="En İyiler"
            ContentTemplate="{DataTemplate local:PopularGamesPage}"
            Route="PopularGamesPage" />
        <ShellContent
            Title="Favoriler"
            ContentTemplate="{DataTemplate local:FavoritesPage}"
            Route="FavoritesPage" />
    </TabBar>
</Shell>