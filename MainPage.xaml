<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DiscoveryApp.MainPage"
             Title="Popüler Oyunlar"
             BackgroundColor="#121212">
    <ContentPage.ToolbarItems>
    </ContentPage.ToolbarItems>
    <Shell.TitleView>
        <Grid ColumnDefinitions="*, Auto" 
              Padding="0,0,10,0">
            <Label Grid.Column="0"
               Text="Popüler Oyunlar"
               TextColor="White"
               FontSize="36"
               FontAttributes="Bold"
               VerticalOptions="Center" />
            <Button Grid.Column="1"
                Text="Çıkış Yap"
                Clicked="OnLogoutClicked"
                BackgroundColor="#E53935"
                TextColor="White"
                FontAttributes="Bold"
                FontSize="20"
                CornerRadius="10"
                HeightRequest="0"
                Padding="15,0"
                VerticalOptions="Center" />
        </Grid>
    </Shell.TitleView>
    <Grid Padding="15"
          RowDefinitions="Auto, Auto, *">
        <SearchBar Grid.Row="0"
                   Placeholder="Oyun ara... (Örn: Cyberpunk)"
                   TextChanged="OnSearchTextChanged"
                   BackgroundColor="#1E1E1E"
                   TextColor="White"
                   CancelButtonColor="White"
                   Margin="0,0,0,5" />
        <Frame Grid.Row="1"
               BackgroundColor="#1E1E1E"
               Margin="0,0,0,10" 
               Padding="5"
               CornerRadius="10">
            <Grid ColumnDefinitions="*, *"
                  ColumnSpacing="10"
                  Margin="0,0,0,10">
                <Frame Grid.Column="0" 
                       Padding="5">
                    <Picker x:Name="CategoryPicker" 
                            Title="Kategori Seçin"
                            SelectedIndexChanged="OnCategoryChanged">
                        <Picker.Items>
                            <x:String>Hepsi</x:String>
                            <x:String>Aksiyon</x:String>
                            <x:String>Macera</x:String>
                            <x:String>RPG</x:String>
                            <x:String>Strateji</x:String>
                            <x:String>Spor</x:String>
                        </Picker.Items>
                    </Picker>
                </Frame>
                <Frame Grid.Column="1" Padding="5">
                    <Picker x:Name="SortPicker" 
                            Title="Sıralama"
                            SelectedIndexChanged="OnSortChanged">
                        <Picker.Items>
                            <x:String>İsim (A-Z)</x:String>
                            <x:String>Yeni (Çıkış Tarihi)</x:String>
                        </Picker.Items>
                    </Picker>
                </Frame>
            </Grid>
        </Frame>
        <CollectionView x:Name="PopularGamesList"
                        Grid.Row="2"
                        SelectionMode="Single"
                        SelectionChanged="OnGameSelected"
                        RemainingItemsThreshold="2" 
                        RemainingItemsThresholdReached="OnScrolledToBottom">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,0,0,15" Padding="0" 
                           CornerRadius="12" 
                           BorderColor="Transparent" 
                           BackgroundColor="#1E1E1E">
                        <Grid ColumnDefinitions="120, *"
                              HeightRequest="120">
                            <Image Grid.Column="0" 
                                   Source="{Binding ImageUrl}" 
                                   Aspect="AspectFill" />
                            <VerticalStackLayout Grid.Column="1" 
                                                 Padding="15" Spacing="8" 
                                                 VerticalOptions="Center">
                                <Label Text="{Binding Name}"
                                       FontSize="18" 
                                       FontAttributes="Bold" 
                                       TextColor="White" 
                                       MaxLines="1" 
                                       LineBreakMode="TailTruncation" />
                                <Label Text="{Binding ReleasedDate, StringFormat='Çıkış: {0}'}"
                                       FontSize="14" 
                                       TextColor="#AAAAAA" />
                                <Label Text="{Binding Rating, StringFormat='★ {0}'}"
                                       FontSize="14"
                                       FontAttributes="Bold" 
                                       TextColor="#FFD700" />
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>