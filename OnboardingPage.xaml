<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DiscoveryApp.OnboardingPage"
             BackgroundColor="#121212"
             NavigationPage.HasNavigationBar="False">
    <Grid RowDefinitions="*, Auto, Auto"
          Padding="20">
        <CarouselView x:Name="IntroCarousel"
                      ItemsSource="{Binding IntroItems}"
                      Grid.Row="0">
            <CarouselView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <VerticalStackLayout VerticalOptions="Center" 
                                             HorizontalOptions="Center" 
                                             Spacing="20">
                            <Label Text="{Binding Icon}"
                                   FontSize="120"
                                   HorizontalOptions="Center"
                                   Margin="0,0,0,30" />
                            <Label Text="{Binding Title}"
                                   FontSize="26"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="{Binding Description}"
                                   FontSize="16"
                                   TextColor="#AAAAAA"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"
                                   Margin="20,0" />
                        </VerticalStackLayout>
                    </Grid>
                </DataTemplate>
            </CarouselView.ItemTemplate>
        </CarouselView>
        <IndicatorView x:Name="Noktalar"
                       Grid.Row="1"
                       IndicatorsShape="Circle"
                       IndicatorColor="#555555"
                       SelectedIndicatorColor="#E50914"
                       HorizontalOptions="Center"
                       Margin="0, 10, 0, 40" />
        <Grid Grid.Row="2" 
              ColumnDefinitions="*, *"
              ColumnSpacing="15" 
              Margin="0,0,0,10">
            <Button Grid.Column="0"
                    Text="Atla"
                    Clicked="OnSkipClicked"
                    BackgroundColor="Transparent"
                    TextColor="#AAAAAA"
                    FontAttributes="Bold"
                    FontSize="16" />
            <Button Grid.Column="1"
                    Text="İleri ❯"
                    Clicked="OnNextClicked"
                    BackgroundColor="#E50914"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="55"
                    FontSize="16" />
        </Grid>
    </Grid>
</ContentPage>